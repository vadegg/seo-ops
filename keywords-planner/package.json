{
  "name": "keywords-planner",
  "version": "1.0.0",
  "description": "Standalone workspace for the keyword-agent pipeline.",
  "main": "dist/cli/index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "keyword:agent:start": "tsx src/cli/index.ts start",
    "keyword:agent:resume": "tsx src/cli/index.ts resume",
    "keyword:agent:volume": "tsx src/cli/index.ts volume",
    "keyword:agent:report": "tsx src/cli/index.ts report",
    "test": "tsx --test tests/*.test.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "cheerio": "^1.2.0",
    "csv-parse": "^6.2.1",
    "csv-stringify": "^6.7.0",
    "dotenv": "^17.4.2",
    "js-yaml": "^4.1.1",
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
